<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AppLimiter"
        android:textSize="24sp"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Limiting: Instagram"
        android:layout_marginBottom="16dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Minutes allowed per hour:"/>

    <EditText
        android:id="@+id/minutesInput"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:inputType="number"
        android:hint="e.g. 10"/>

    <Button
        android:id="@+id/saveButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Save Limit"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/accessibilityButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Step 1: Enable Accessibility Permission"
        android:layout_marginTop="24dp"/>

    <Button
        android:id="@+id/usageAccessButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Step 2: Enable Usage Access Permission"
        android:layout_marginTop="8dp"/>

</LinearLayout>
